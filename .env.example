# ── ELYSIAN Backend Environment Variables ──
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Anthropic (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase (get from supabase.com → your project → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Mapbox (get from account.mapbox.com → tokens)
MAPBOX_ACCESS_TOKEN=pk.your-token-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# USGS MRDS — no key needed, it's public
USGS_MRDS_BASE=https://mrdata.usgs.gov/services/wfs/mrds
